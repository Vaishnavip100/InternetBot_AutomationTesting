<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="InternetBot Suite" parallel="classes" thread-count="2">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryListener"/>
    </listeners>

    <test name="Authentication Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Alerts Tests">
        <classes>
            <class name="tests.AlertsTest"/>
        </classes>
    </test>

    <test name="Checkbox Dropdown Tests">
        <classes>
            <class name="tests.CheckboxesAndDropdownsTest"/>
        </classes>
    </test>

    <test name="File Upload Tests">
        <classes>
            <class name="tests.FileUploadTest"/>
        </classes>
    </test>

    <test name="Dynamic Loading Tests">
        <classes>
            <class name="tests.DynamicLoadingTest"/>
        </classes>
    </test>

</suite>